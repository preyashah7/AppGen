{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://appgen.local/schemas/appgen.schema.json",
  "title": "AppGen Configuration Schema",
  "description": "Root schema for AppGen JSON configurations. Use this file as the reference for building, validating, and editing app configs.",
  "type": "object",
  "additionalProperties": false,
  "required": ["settings", "localization", "entities", "pages", "dashboard"],
  "properties": {
    "settings": {
      "type": "object",
      "additionalProperties": false,
      "required": ["app_name", "theme", "default_language", "icon", "color"],
      "properties": {
        "app_name": {
          "type": "string",
          "minLength": 1,
          "description": "Display name of the generated app shown in the sidebar, login screens, and browser title."
        },
        "theme": {
          "type": "string",
          "enum": ["light", "dark"],
          "description": "Visual theme for the generated app."
        },
        "default_language": {
          "type": "string",
          "minLength": 2,
          "description": "Default UI language code used when the app opens for the first time."
        },
        "icon": {
          "type": "string",
          "minLength": 1,
          "description": "Name of the icon used for the app in the sidebar and dashboard. Example: Layers, Coffee, CheckSquare."
        },
        "color": {
          "type": "string",
          "pattern": "^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})$",
          "description": "Primary brand color in hex format."
        },
        "description": {
          "type": "string",
          "description": "Short description of the app. Optional, but useful for demo apps and generated previews."
        }
      }
    },
    "localization": {
      "type": "object",
      "description": "Language packs keyed by locale code. Each locale contains the translated labels used throughout the UI.",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/localizationPack"
      }
    },
    "settings_ui": {
      "type": "object",
      "description": "Optional feature flags that control what appears in the UI.",
      "additionalProperties": false,
      "properties": {
        "show_notifications": { "type": "boolean", "default": true },
        "show_search": { "type": "boolean", "default": true },
        "show_language_switcher": { "type": "boolean", "default": true },
        "allow_csv_import": { "type": "boolean", "default": true },
        "allow_github_export": { "type": "boolean", "default": true }
      }
    },
    "entities": {
      "type": "array",
      "minItems": 1,
      "description": "List of dynamically generated entities. Each entity becomes a route, form, table, and data source.",
      "items": { "$ref": "#/$defs/entity" }
    },
    "pages": {
      "type": "array",
      "minItems": 1,
      "description": "Explicit page definitions for the sidebar and route system.",
      "items": { "$ref": "#/$defs/page" }
    },
    "dashboard": {
      "type": "array",
      "minItems": 1,
      "description": "Dashboard widgets rendered on the app home page.",
      "items": { "$ref": "#/$defs/dashboardWidget" }
    }
  },
  "$defs": {
    "localizationPack": {
      "type": "object",
      "description": "Translation map for a single language.",
      "additionalProperties": {
        "type": "string"
      },
      "properties": {
        "app_name": { "type": "string" },
        "dashboard": { "type": "string" },
        "create": { "type": "string" },
        "edit": { "type": "string" },
        "delete": { "type": "string" },
        "save": { "type": "string" },
        "cancel": { "type": "string" },
        "search": { "type": "string" },
        "no_data": { "type": "string" },
        "loading": { "type": "string" },
        "notifications": { "type": "string" },
        "config_editor": { "type": "string" }
      }
    },
    "entity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "display_name", "fields"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$",
          "description": "Machine-readable entity key used in routes, database records, and config references."
        },
        "display_name": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable entity label shown in the UI."
        },
        "icon": {
          "type": "string",
          "description": "Optional Lucide icon name for the sidebar and page header."
        },
        "description": {
          "type": "string",
          "description": "Optional text describing what this entity is for."
        },
        "permissions": {
          "$ref": "#/$defs/permissions"
        },
        "fields": {
          "type": "array",
          "minItems": 1,
          "description": "Field definitions used to generate the create/edit form and table columns.",
          "items": { "$ref": "#/$defs/field" }
        }
      }
    },
    "permissions": {
      "type": "object",
      "additionalProperties": false,
      "description": "CRUD permissions for the entity.",
      "properties": {
        "create": { "type": "boolean", "default": true },
        "read": { "type": "boolean", "default": true },
        "update": { "type": "boolean", "default": true },
        "delete": { "type": "boolean", "default": true }
      }
    },
    "field": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "label", "type"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$",
          "description": "Field key stored in database records and used by CSV import/export."
        },
        "label": {
          "type": "string",
          "minLength": 1,
          "description": "Field label shown in forms, tables, and filters."
        },
        "type": {
          "type": "string",
          "enum": ["text", "textarea", "select", "checkbox", "email", "number", "date", "url", "phone"],
          "description": "Input type used to render the field. Unknown types should fall back safely in the runtime."
        },
        "required": {
          "type": "boolean",
          "default": false,
          "description": "Marks the field as required in the form validation layer."
        },
        "placeholder": {
          "type": "string",
          "description": "Placeholder text shown in input fields."
        },
        "default_value": {
          "description": "Default value applied when creating a new record.",
          "oneOf": [
            { "type": "string" },
            { "type": "number" },
            { "type": "boolean" },
            { "type": "null" }
          ]
        },
        "options": {
          "type": "array",
          "description": "Options used for select fields.",
          "items": { "$ref": "#/$defs/selectOption" }
        },
        "help_text": {
          "type": "string",
          "description": "Optional helper text for the field."
        },
        "validation": {
          "type": "object",
          "description": "Optional validation hints for future extension.",
          "additionalProperties": true
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "type": { "const": "select" } },
            "required": ["type"]
          },
          "then": {
            "required": ["options"]
          }
        }
      ]
    },
    "selectOption": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "label"],
      "properties": {
        "value": {
          "type": "string",
          "minLength": 1,
          "description": "Stored value for the select option."
        },
        "label": {
          "type": "string",
          "minLength": 1,
          "description": "Visible text shown in the dropdown."
        }
      }
    },
    "page": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "title", "entity"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["table", "form", "dashboard", "custom"],
          "description": "Page layout type."
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "description": "Page title shown in the sidebar and header."
        },
        "entity": {
          "type": "string",
          "minLength": 1,
          "description": "Entity key this page is bound to."
        },
        "columns": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Table columns to render for this page."
        },
        "filters": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Fields available as filters in the UI."
        },
        "actions": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["create", "edit", "delete", "import", "export"]
          },
          "description": "Allowed actions on the page."
        },
        "component": {
          "type": "string",
          "description": "Optional custom component key for advanced page rendering."
        }
      }
    },
    "dashboardWidget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "title", "entity"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["stat", "chart", "recent"],
          "description": "Widget type shown on the dashboard."
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "description": "Widget title."
        },
        "entity": {
          "type": "string",
          "minLength": 1,
          "description": "Entity key used by the widget."
        },
        "aggregation": {
          "type": "string",
          "enum": ["count", "sum", "avg"],
          "description": "Aggregation used by stat widgets."
        },
        "group_by": {
          "type": "string",
          "description": "Field name used to group chart data."
        },
        "limit": {
          "type": "integer",
          "minimum": 1,
          "description": "Maximum number of records for recent widgets."
        },
        "icon": {
          "type": "string",
          "description": "Optional icon name for the widget."
        },
        "span": {
          "type": "integer",
          "minimum": 1,
          "maximum": 4,
          "default": 1,
          "description": "Grid width for dashboard layout."
        }
      }
    }
  },
  "examples": [
    {
      "settings": {
        "app_name": "Operations Hub",
        "theme": "light",
        "default_language": "en",
        "icon": "Layers",
        "color": "#2563EB"
      },
      "localization": {
        "en": {
          "app_name": "Operations Hub",
          "dashboard": "Dashboard",
          "create": "Create",
          "edit": "Edit",
          "delete": "Delete",
          "save": "Save",
          "cancel": "Cancel",
          "search": "Search",
          "no_data": "No data found",
          "loading": "Loading...",
          "notifications": "Notifications",
          "config_editor": "Config Editor"
        }
      },
      "entities": [
        {
          "name": "tasks",
          "display_name": "Tasks",
          "icon": "CheckSquare",
          "fields": [
            { "name": "title", "label": "Title", "type": "text", "required": true },
            { "name": "status", "label": "Status", "type": "select", "options": [
              { "value": "todo", "label": "To Do" },
              { "value": "doing", "label": "Doing" },
              { "value": "done", "label": "Done" }
            ] }
          ],
          "permissions": { "create": true, "read": true, "update": true, "delete": true }
        }
      ],
      "pages": [
        {
          "type": "table",
          "title": "Tasks",
          "entity": "tasks",
          "columns": ["title", "status"],
          "filters": ["status"],
          "actions": ["create", "edit", "delete"]
        }
      ],
      "dashboard": [
        {
          "type": "stat",
          "title": "Tasks",
          "entity": "tasks",
          "aggregation": "count",
          "icon": "CheckSquare",
          "span": 1
        }
      ]
    }
  ]
}
